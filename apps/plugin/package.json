{
  "name": "plugin",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 0.0.0.0 --port 3004 --clearScreen false",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "clean": "rm -rf dist .turbo .wrangler dist node_modules",
    "pack": "npx framer-plugin-tools@latest pack"
  },
  "dependencies": {
    "@framer-university/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "api": "workspace:*",
    "@framer-university/eslint-config": "workspace:*",
    "@framer-university/typescript-config": "workspace:*",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "@cloudflare/vite-plugin": "^1.0.0",
    "eslint": "^9.25.0",
    "typescript": "5.8.2",
    "vite": "^6.3.4",
    "tailwindcss": "^4.1.4",
    "@tailwindcss/postcss": "^4.0.0",
    "wrangler": "^4.16.0"
  }
}
