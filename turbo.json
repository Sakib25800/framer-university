{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "remoteCache": {
    "signature": true
  },
  "globalPassThroughEnv": [],
  "globalEnv": [
    "DATABASE_URL",
    "API_URL",
    "CARGO_INCREMENTAL",
    "CARGO_PROFILE_DEV_DEBUG", 
    "CARGO_TERM_COLOR",
    "RUST_BACKTRACE",
    "RUSTFLAGS",
    "CARGO_UNSTABLE_SPARSE_REGISTRY",
    "CARGO_REGISTRIES_CRATES_IO_PROTOCOL",
    "CACHE_ON_FAILURE"
  ],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "dependsOn": ["^build"],
      "outputs": ["build/**", "dist/**", "storybook-static/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build", "^lint"]
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "test": {
      "dependsOn": ["^build", "^test"]
    },
    "test:e2e": {
      "outputs": ["playwright-report", "playwright-results"]
    },
    "clean": {
      "cache": false
    }
  }
}
